# =============================================================================
# OctoMate — environment variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ---- Model (OpenAI-compatible endpoint) ----
# Default: Nosana-hosted Qwen3.5-9B-FP8 (free for challenge participants).
# No real API key needed — "nosana" is the convention.
OPENAI_API_BASE_URL=https://5i8frj7ann99bbw9gzpprvzj2esugg39hxbb4unypskq.node.k8s.prd.nos.ci/v1
OPENAI_API_KEY=nosana
OPENAI_MODEL=Qwen3.5-9B-FP8

# --- Alternative: OpenAI ---
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Alternative: local Ollama ---
# OPENAI_API_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=qwen2.5:7b

# ---- Ports ----
# PORT = Next.js (public), AGENT_PORT = ElizaOS agent (internal).
# NOTE: docker --env-file does NOT strip inline comments the way dotenv
# does, so keep these on their own lines — no trailing "# comment" —
# or the docker container will ship junk values.
PORT=3000
AGENT_PORT=4111

# ---- Optional: server-side default GitHub PAT (users can also supply via UI) ----
GITHUB_TOKEN=

# ---- Runtime ----
NODE_ENV=development
LOG_LEVEL=info
